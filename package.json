{
  "name": "crucix",
  "version": "2.0.3",
  "description": "Local intelligence engine - 27 OSINT sources, live dashboard, public demo at crucix.live, auto-refresh, optional LLM layer.",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 stop crucix",
    "logs:pm2": "pm2 logs crucix",
    "dev": "node --trace-warnings server.mjs",
    "sweep": "node apis/briefing.mjs",
    "inject": "node dashboard/inject.mjs",
    "brief": "node apis/briefing.mjs",
    "brief:save": "node apis/save-briefing.mjs",
    "diag": "node diag.mjs",
    "clean": "node scripts/clean.mjs",
    "fresh-start": "npm run clean && npm start",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npx ng serve --open",
    "frontend:build": "cd frontend && npx ng build --configuration production",
    "frontend:watch": "cd frontend && npx ng build --watch --configuration development"
  },
  "keywords": [
    "osint",
    "intelligence",
    "dashboard",
    "geopolitical"
  ],
  "author": "Crucix",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-basic-auth": "^1.2.1",
    "express-rate-limit": "^8.3.2",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7",
    "xml2js": "^0.6.2"
  },
  "optionalDependencies": {
    "discord.js": "^14.25.1"
  },
  "overrides": {
    "undici": "^7.24.4"
  }
}
